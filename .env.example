# Quelora — production environment
#
# Copy to .env and fill in. NEVER commit your real .env.
#
# Required: the items marked ★ — everything else has sensible defaults.

# ─── Core URLs ── replace example.com with your domain ★ ────────────────
BASE_URL=https://api.example.com
CLIENT_URL=https://example.com
DASHBOARD_URL=https://dashboard.example.com

# ─── Database & cache ── usually leave these as-is for the bundled compose
MONGO_URI=mongodb://mongo:27017/quelora
MONGO_SYNC_INDEXES=true
CACHE_REDIS_URL=redis://redis:6379
CACHE_URL=redis://redis:6379

# ─── Secrets ── GENERATE FRESH ★ ────────────────────────────────────────
#   openssl rand -hex 32   for each of the JWT secrets
#   openssl rand -hex 32   for ENCRYPTION_KEY (must be 64-char hex)
JWT_SECRET=
JWT_TTL=72h
JWT_ADMIN_SECRET=
JWT_ADMIN_TTL=72h
ENCRYPTION_KEY=

# ─── Comments / defaults ────────────────────────────────────────────────
LIMIT_COMMENTS=15
DEFAULT_LANGUAGE=en

# ─── LLM moderation (optional — leave blank to disable) ────────────────
# Quelora can route moderation to OpenAI / Gemini / Grok / DeepSeek, or to
# the self-hosted quelora-detoxify service. Configure per-client in the
# dashboard; these env vars are the default fallback for OpenAI.
MODEL=gpt-4o
TEMPERATURE=0
MAX_TOKENS=1000
API_KEY=
MAX_RETRIES=5
TIMEOUT=20000

# ─── Toxicity scoring (Google Perspective — optional) ─────────────────
PERSPECTIVE_API_URL=https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze
PERSPECTIVE_API_KEY=
TOXICITY_THRESHOLD=0.7

# ─── Translation (Google Translate — optional) ────────────────────────
TRANSLATE_API_URL=https://translation.googleapis.com/language/translate/v2
TRANSLATE_DETECT_API_URL=https://translation.googleapis.com/language/translate/v2/detect
TRANSLATE_API_KEY=

# ─── Language detection (detectlanguage.com — optional) ───────────────
DL_URL=https://ws.detectlanguage.com/0.2/detect
DL_API_KEY=

# ─── GIF picker (Giphy — optional) ────────────────────────────────────
GIPHY_API_KEY=
GIPHY_SEARCH_URL=https://api.giphy.com/v1/gifs/search

# ─── Web Push (VAPID — for notifications) ─────────────────────────────
#   web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ─── SMTP (transactional email — pick a provider or run your own) ─────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ─── Sentinel debug broker (the dashboard-api WebSocket) ──────────────
#   openssl rand -hex 32
INTERNAL_AI_SECRET=

# ─── BullMQ worker tuning ─────────────────────────────────────────────
WORKER_CONCURRENCY=10
WORKER_MAX_JOBS_PER_SECOND=5000
WORKER_MAX_RETRIES=3
WORKER_BACKOFF_DELAY_MS=1000
WORKER_REMOVE_COMPLETED_JOBS=true
WORKER_REMOVE_FAILED_JOBS=1000

# ─── Feature flags ────────────────────────────────────────────────────
DISABLE_RESPONSE_COMPRESSOR=0
QUELORA_EDITION=community           # 'community' or 'enterprise' (if you install the module)

# ─── Tenant identity ──────────────────────────────────────────────────
# A primary CID for the instance. Format: QU-XXXXXXXX-XXXXX (you'll
# generate more via the dashboard once it's running.)
CID=QU-XXXXXXXX-XXXXX

# ─── Cron / job runner ────────────────────────────────────────────────
RUNS_CRON=true

# ─── Server tuning ────────────────────────────────────────────────────
PORT=3000
NODE_NO_WARNINGS=1
